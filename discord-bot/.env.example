# Get from Discord Developer Portal > your bot > Token
DISCORD_TOKEN=your_bot_token_here

# Right-click the channel in Discord > Copy Channel ID
DISCORD_CHANNEL_ID=your_channel_id_here

# Your deployed Vercel URL
SITE_URL=https://fivem-stats.vercel.app

# Optional: comma-separated server codes to post (e.g. 3lamjz,oax3mk7)
# Leave blank to post ALL active servers
SERVER_CODES=
